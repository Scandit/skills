<?xml version='1.0' encoding='utf-8'?>
<widget id="com.example.idscanner" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>IdScanner</name>
    <description>ID Capture sample (v7).</description>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <preference name="DisallowOverscroll" value="true" />
    <preference name="android-minSdkVersion" value="23" />

    <platform name="android">
        <allow-intent href="market:*" />
    </platform>
    <platform name="ios">
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
    </platform>

    <!-- v7 ID Capture plugins -->
    <plugin name="scandit-cordova-datacapture-core" spec="^7.0.0" />
    <plugin name="scandit-cordova-datacapture-id" spec="^7.0.0" />
</widget>
